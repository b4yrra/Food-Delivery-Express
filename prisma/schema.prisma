generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Food { 
  id    Int     @id @default(autoincrement()) 
  name String
  price String
  img String
  ingredients String
  category FoodCategory @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId Int
  foodOrderItems FoodOrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 

model FoodCategory { 
  id  Int     @id @default(autoincrement()) 
  categoryName  String
  foods Food[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  role Role @default(User)
  password String
  orders FoodOrder[]
  ttl DateTime @default(now())
  address String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  User
  Admin
}

model FoodOrder {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id])
  totalPrice String
  status FoodOrderStatus @default(Pending)
  foodOrderItems FoodOrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

enum FoodOrderStatus {
  Pending
  Canceled
  Delivered
}

model FoodOrderItem {
  id Int @id @default(autoincrement())
  quantity Int
  food Food @relation(fields: [foodId], references: [id])
  foodId Int
  order FoodOrder @relation(fields: [foodOrderId], references: [id])
  foodOrderId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}