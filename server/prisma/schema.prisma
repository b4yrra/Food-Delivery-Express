generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Food {
  id             Int             @id @default(autoincrement())
  name           String
  price          String
  foodCategoryId Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  img            String
  ingredients    String
  category       FoodCategory    @relation(fields: [foodCategoryId], references: [id])
  foodOrderItems FoodOrderItem[]
}

model FoodCategory {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  categoryName String
  foods        Food[]
}

model User {
  id        Int         @id @default(autoincrement())
  email     String      @unique
  role      Role        @default(User)
  password  String
  ttl       DateTime    @default(now())
  address   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  orders    FoodOrder[]
}

model FoodOrder {
  id             Int             @id @default(autoincrement())
  userId         Int
  totalPrice     String
  status         FoodOrderStatus @default(Pending)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id])
  foodOrderItems FoodOrderItem[]
}

model FoodOrderItem {
  id          Int       @id @default(autoincrement())
  quantity    Int
  foodId      Int
  foodOrderId Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  food        Food      @relation(fields: [foodId], references: [id])
  order       FoodOrder @relation(fields: [foodOrderId], references: [id])
}

enum Role {
  User
  Admin
}

enum FoodOrderStatus {
  Pending
  Cancelled
  Delivered
}
